BOT_TOKEN=YOUR_BOT_TOKEN_HERE
ADMIN_ID=YOUR_ADMIN_ID
# Private channel where movies are posted for the bot to pick up (bot must be an admin there).
# Leave unset at first: the bot logs every channel_post's chat.id, so you can copy the right
# value here once you see it in the logs.
STORAGE_CHANNEL_ID=YOUR_STORAGE_CHANNEL_ID
# Shown to users on the payment screen. Leave unset to show a "coming soon" placeholder instead.
PAYMENT_CARD=YOUR_CARD_NUMBER
PAYMENT_CARD_NAME=YOUR_CARD_HOLDER_NAME
